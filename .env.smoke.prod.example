# Copy to .env.smoke.prod.local and replace one-time values before a real prod deployed smoke.
# Do not commit .env.smoke.prod.local.
# Load with: set -a; source .env.smoke.prod.local; set +a
# Production main-flow smoke writes real data. Keep the opt-in false until the exact run is approved.

GOODS_COMM_SMOKE_API_BASE_URL=https://api.your-domain.example
GOODS_COMM_SMOKE_ALLOW_PROD_MUTATION=false

GOODS_COMM_SMOKE_SELLER_PROVIDER=weixin
GOODS_COMM_SMOKE_SELLER_CODE=REPLACE_WITH_ONE_TIME_PROD_SELLER_LOGIN_CODE
GOODS_COMM_SMOKE_BUYER_PROVIDER=weixin
GOODS_COMM_SMOKE_BUYER_CODE=REPLACE_WITH_ONE_TIME_PROD_BUYER_LOGIN_CODE

GOODS_COMM_SMOKE_LATITUDE=31.22945
GOODS_COMM_SMOKE_LONGITUDE=121.45494
GOODS_COMM_SMOKE_ACCURACY=30
GOODS_COMM_SMOKE_SCOPE_TYPE=community
GOODS_COMM_SMOKE_RADIUS_METERS=1200
GOODS_COMM_SMOKE_RUN_ID=prod-manual-smoke-YYYYMMDDHHmm

GOODS_COMM_SMOKE_HEALTH_ATTEMPTS=12
GOODS_COMM_SMOKE_HEALTH_INTERVAL_MS=10000

GOODS_COMM_SMOKE_APPROVED_IMAGE_URL=https://cdn.your-domain.example/assets/smoke-approved.jpg
GOODS_COMM_SMOKE_APPROVED_IMAGE_STORAGE_KEY=smoke/approved-image.jpg
GOODS_COMM_SMOKE_APPROVED_IMAGE_SIZE=1
GOODS_COMM_SMOKE_APPROVED_IMAGE_MIME_TYPE=image/jpeg
GOODS_COMM_SMOKE_APPROVED_IMAGE_CHECKSUM=

GOODS_COMM_SMOKE_ACCOUNT_DELETE_PROVIDER=weixin
GOODS_COMM_SMOKE_ACCOUNT_DELETE_CODE=REPLACE_WITH_OPTIONAL_DISPOSABLE_PROD_ACCOUNT_DELETE_CODE
