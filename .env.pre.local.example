# Copy to .env.pre.local and replace every value before a real pre deployment.
# Do not commit .env.pre.local.

VITE_API_BASE_URL=https://pre-api.your-domain.example
GOODS_COMM_CLOUDBASE_ENV_ID=your-pre-cloudbase-env
GOODS_COMM_TENCENT_REGION=ap-shanghai
GOODS_COMM_TENCENT_CLOUD_RUN_SERVICE=goods-comm-pre-backend
GOODS_COMM_TENCENT_CONTAINER_IMAGE=ccr.ccs.tencentyun.com/your-namespace/goods-comm-pre-backend:latest
GOODS_COMM_ALLOWED_ORIGINS=https://pre.your-domain.example

GOODS_COMM_DATABASE_URL=postgres://goods_comm_pre_app:REPLACE_WITH_REAL_PRE_DB_PASSWORD@pre-pg.internal.example:5432/goods_comm_pre
GOODS_COMM_DATABASE_SCHEMA=public
GOODS_COMM_STATE_STORE=postgres
GOODS_COMM_POSTGRES_AUTO_SCHEMA=false

GOODS_COMM_OBJECT_STORE=cos
GOODS_COMM_PUBLIC_ASSET_BASE_URL=https://pre-cdn.your-domain.example/assets
GOODS_COMM_COS_BUCKET=goods-comm-pre-real-bucket
GOODS_COMM_COS_REGION=ap-shanghai
GOODS_COMM_COS_SECRET_ID=REPLACE_WITH_REAL_PRE_COS_SECRET_ID
GOODS_COMM_COS_SECRET_KEY=REPLACE_WITH_REAL_PRE_COS_SECRET_KEY
GOODS_COMM_COS_BASE_URL=https://goods-comm-pre-real-bucket.cos.ap-shanghai.myqcloud.com
GOODS_COMM_CDN_BASE_URL=https://pre-cdn.your-domain.example/assets

GOODS_COMM_MAP_PROVIDER=tencent
GOODS_COMM_TENCENT_MAP_KEY=REPLACE_WITH_REAL_PRE_TENCENT_MAP_KEY
GOODS_COMM_MAP_REGION_DATASET=[{"adcode":"310106","streetName":"nanjing-west-road","communityId":"pre-real-community-1","communityName":"Pre Real Community 1","streetId":"pre-real-street-1"}]

GOODS_COMM_CONTENT_SECURITY_PROVIDER=wechat
GOODS_COMM_MODERATION_WEBHOOK_SECRET=REPLACE_WITH_REAL_PRE_MODERATION_WEBHOOK_SECRET
GOODS_COMM_SESSION_SECRET=REPLACE_WITH_REAL_PRE_SESSION_SECRET
GOODS_COMM_OPS_SESSION_SECRET=REPLACE_WITH_REAL_PRE_OPS_SESSION_SECRET
GOODS_COMM_OPS_ACCOUNTS=ops-support:REPLACE_WITH_REAL_PRE_OPS_PASSWORD:moderation|support|notifications|telemetry|risk

GOODS_COMM_TRUSTED_PROXY_IPS=REPLACE_WITH_REAL_PRE_PROXY_IP_OR_CIDR
GOODS_COMM_ALERT_PROVIDER=webhook
GOODS_COMM_ALERT_WEBHOOK_URL=https://pre-alerts.your-domain.example/webhooks/goods-comm
GOODS_COMM_ALERT_WEBHOOK_TOKEN=REPLACE_WITH_REAL_PRE_ALERT_WEBHOOK_TOKEN
GOODS_COMM_ACCESS_LOG_ENABLED=true

GOODS_COMM_PLATFORM_AUTH_MODE=platform
GOODS_COMM_WECHAT_APP_ID=REPLACE_WITH_REAL_PRE_WECHAT_APP_ID
GOODS_COMM_WECHAT_APP_SECRET=REPLACE_WITH_REAL_PRE_WECHAT_APP_SECRET
GOODS_COMM_ALIPAY_APP_ID=REPLACE_WITH_REAL_PRE_ALIPAY_APP_ID
GOODS_COMM_ALIPAY_PRIVATE_KEY=REPLACE_WITH_REAL_PRE_ALIPAY_PRIVATE_KEY

GOODS_COMM_PLATFORM_NOTIFY_PROVIDER=wechat
GOODS_COMM_WECHAT_SUBSCRIBE_TEMPLATE_IDS=trade_created:REPLACE_WITH_REAL_PRE_TEMPLATE_TRADE_CREATED,trade_confirmed:REPLACE_WITH_REAL_PRE_TEMPLATE_TRADE_CONFIRMED,trade_completed:REPLACE_WITH_REAL_PRE_TEMPLATE_TRADE_COMPLETED,trade_cancelled:REPLACE_WITH_REAL_PRE_TEMPLATE_TRADE_CANCELLED,trade_disputed:REPLACE_WITH_REAL_PRE_TEMPLATE_TRADE_DISPUTED,trade_dispute_resolved:REPLACE_WITH_REAL_PRE_TEMPLATE_TRADE_DISPUTE_RESOLVED,trade_reviewed:REPLACE_WITH_REAL_PRE_TEMPLATE_TRADE_REVIEWED
