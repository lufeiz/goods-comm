# Copy to .env.smoke.pre.local and replace one-time values before a real pre deployed smoke.
# Do not commit .env.smoke.pre.local.
# Deployed smoke scripts auto-load .env.smoke.pre.local. Export manually only for ad-hoc shell calls.

GOODS_COMM_SMOKE_API_BASE_URL=https://pre-api.your-domain.example

GOODS_COMM_SMOKE_SELLER_PROVIDER=weixin
GOODS_COMM_SMOKE_SELLER_CODE=REPLACE_WITH_ONE_TIME_PRE_SELLER_LOGIN_CODE
GOODS_COMM_SMOKE_BUYER_PROVIDER=weixin
GOODS_COMM_SMOKE_BUYER_CODE=REPLACE_WITH_ONE_TIME_PRE_BUYER_LOGIN_CODE

GOODS_COMM_SMOKE_LATITUDE=31.22945
GOODS_COMM_SMOKE_LONGITUDE=121.45494
GOODS_COMM_SMOKE_ACCURACY=30
GOODS_COMM_SMOKE_SCOPE_TYPE=community
GOODS_COMM_SMOKE_RADIUS_METERS=1200
GOODS_COMM_SMOKE_RUN_ID=pre-manual-smoke-YYYYMMDDHHmm
# Optional: fix capturedAt only when retrying the same run id and the timestamp is still within location freshness limits.
# GOODS_COMM_SMOKE_CAPTURED_AT=1780220000000

GOODS_COMM_SMOKE_HEALTH_ATTEMPTS=12
GOODS_COMM_SMOKE_HEALTH_INTERVAL_MS=10000

GOODS_COMM_SMOKE_APPROVED_IMAGE_URL=https://pre-cdn.your-domain.example/assets/smoke-approved.jpg
GOODS_COMM_SMOKE_APPROVED_IMAGE_STORAGE_KEY=smoke/approved-image.jpg
GOODS_COMM_SMOKE_APPROVED_IMAGE_SIZE=1
GOODS_COMM_SMOKE_APPROVED_IMAGE_MIME_TYPE=image/jpeg
GOODS_COMM_SMOKE_APPROVED_IMAGE_CHECKSUM=

GOODS_COMM_SMOKE_ACCOUNT_DELETE_PROVIDER=weixin
GOODS_COMM_SMOKE_ACCOUNT_DELETE_CODE=REPLACE_WITH_OPTIONAL_DISPOSABLE_PRE_ACCOUNT_DELETE_CODE
GOODS_COMM_SMOKE_ACCOUNT_DELETE_RELOGIN_CODE=REPLACE_WITH_OPTIONAL_SECOND_PRE_ACCOUNT_DELETE_LOGIN_CODE_SAME_ACCOUNT
