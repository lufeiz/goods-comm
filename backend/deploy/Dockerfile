FROM node:20-alpine

WORKDIR /app
COPY . .

ENV NODE_ENV=production
ENV HOST=0.0.0.0
ENV PORT=8787
ENV GOODS_COMM_STATE_PATH=/data/goods-comm-state.json
ENV GOODS_COMM_OBJECT_DIR=/data/object-store
ENV GOODS_COMM_PUBLIC_ASSET_BASE_URL=/assets
ENV GOODS_COMM_OBJECT_STORE=
ENV GOODS_COMM_STATE_STORE=
ENV GOODS_COMM_PLATFORM_AUTH_MODE=
ENV GOODS_COMM_CONTENT_SECURITY_PROVIDER=
ENV GOODS_COMM_MAP_PROVIDER=
ENV GOODS_COMM_ALLOWED_ORIGINS=

RUN npm ci --omit=dev --ignore-scripts && npm cache clean --force

EXPOSE 8787
CMD ["node", "backend/src/server.mjs"]
