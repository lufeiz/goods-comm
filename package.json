{
  "name": "goods-comm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "微信、支付宝平台通用的社区二手交易小程序",
  "scripts": {
    "dev:weixin": "uni -p mp-weixin",
    "dev:alipay": "uni -p mp-alipay",
    "build:weixin": "node scripts/build-weixin.mjs",
    "build:weixin:dev": "node scripts/build-weixin.mjs --mode dev",
    "build:weixin:test": "node scripts/build-weixin.mjs --mode test",
    "build:weixin:pre": "node scripts/build-weixin.mjs --mode pre",
    "build:weixin:prod": "node scripts/build-weixin.mjs --mode prod",
    "build:alipay": "uni build -p mp-alipay",
    "build:alipay:dev": "uni build -p mp-alipay --mode dev --outDir dist/build/dev/mp-alipay",
    "build:alipay:test": "uni build -p mp-alipay --mode test --outDir dist/build/test/mp-alipay",
    "build:alipay:pre": "uni build -p mp-alipay --mode pre --outDir dist/build/pre/mp-alipay",
    "build:alipay:prod": "uni build -p mp-alipay --mode prod --outDir dist/build/prod/mp-alipay",
    "build:h5": "uni build -p h5",
    "build:h5:dev": "uni build -p h5 --mode dev --outDir dist/build/dev/h5",
    "build:h5:test": "uni build -p h5 --mode test --outDir dist/build/test/h5",
    "build:h5:pre": "uni build -p h5 --mode pre --outDir dist/build/pre/h5",
    "build:h5:prod": "uni build -p h5 --mode prod --outDir dist/build/prod/h5",
    "build:backend": "node scripts/build-backend.mjs",
    "backend:dev": "node backend/src/server.mjs",
    "backend:start:dev": "node scripts/start-backend.mjs dev",
    "backend:start:test": "node scripts/start-backend.mjs test",
    "backend:start:pre": "node scripts/start-backend.mjs pre",
    "backend:start:prod": "node scripts/start-backend.mjs prod",
    "env:check": "node scripts/check-environments.mjs",
    "env:check:dev": "node scripts/check-environments.mjs dev",
    "env:check:test": "node scripts/check-environments.mjs test",
    "env:check:pre": "node scripts/check-environments.mjs pre",
    "env:check:prod": "node scripts/check-environments.mjs prod",
    "audit:production-readiness": "node scripts/production-readiness-audit.mjs",
    "audit:production-readiness:strict": "node scripts/production-readiness-audit.mjs --require-deployed-smoke-inputs --output docs/deployment-readiness-audit-strict.md --json-output docs/deployment-readiness-audit-strict.json",
    "audit:production-readiness:strict-check": "node scripts/production-readiness-audit.mjs --check-only --require-deployed-smoke-inputs",
    "verify:release": "node scripts/verify-release-gate.mjs --profile full",
    "verify:release:quick": "node scripts/verify-release-gate.mjs --profile quick",
    "verify:release:strict": "node scripts/verify-release-gate.mjs --profile release",
    "db:migrate:plan": "node scripts/migrate-database.mjs",
    "db:migrate:pre": "node scripts/migrate-database.mjs --env pre --execute",
    "db:migrate:prod": "node scripts/migrate-database.mjs --env prod --execute",
    "deploy:backend:plan": "node scripts/deploy-backend.mjs",
    "deploy:backend:pre:plan": "node scripts/deploy-backend.mjs --env pre",
    "deploy:backend:prod:plan": "node scripts/deploy-backend.mjs --env prod",
    "deploy:backend:pre": "node scripts/deploy-backend.mjs --env pre --execute",
    "deploy:backend:prod": "node scripts/deploy-backend.mjs --env prod --execute",
    "smoke:deployed:pre": "node scripts/deployed-health-smoke.mjs --env pre",
    "smoke:deployed:prod": "node scripts/deployed-health-smoke.mjs --env prod",
    "smoke:deployed:local-health": "node scripts/deployed-health-local-smoke.mjs",
    "smoke:deployed:pre:main": "node scripts/deployed-main-flow-smoke.mjs --env pre",
    "smoke:deployed:prod:main": "node scripts/deployed-main-flow-smoke.mjs --env prod",
    "smoke:deployed:local-main": "node scripts/deployed-main-flow-local-smoke.mjs",
    "sync:prod-to-pre:plan": "node scripts/sync-prod-to-pre.mjs",
    "sync:prod-to-pre": "node scripts/sync-prod-to-pre.mjs --execute",
    "sync:prod-to-pre:auto": "node scripts/sync-prod-to-pre.mjs --auto",
    "smoke:platform-auth": "node scripts/platform-auth-smoke.mjs",
    "smoke:ops-auth": "node scripts/ops-auth-smoke.mjs",
    "smoke:ops-alerts": "node scripts/ops-alerts-smoke.mjs",
    "smoke:platform-notifier": "node scripts/platform-notifier-smoke.mjs",
    "smoke:storage-content": "node scripts/storage-content-smoke.mjs",
    "smoke:rate-limiter": "node scripts/rate-limiter-smoke.mjs",
    "smoke:region": "node scripts/region-resolver-smoke.mjs",
    "smoke:postgres-store": "node scripts/postgres-store-smoke.mjs",
    "smoke:prod-sync": "node scripts/prod-sync-smoke.mjs",
    "smoke:artifacts": "node scripts/artifact-smoke.mjs",
    "smoke:backend:artifact": "node scripts/backend-artifact-smoke.mjs",
    "smoke:pages": "node scripts/page-contract-smoke.mjs",
    "smoke:main-flow-contract": "node scripts/main-flow-contract-smoke.mjs",
    "smoke:h5:render": "node scripts/h5-render-smoke.mjs",
    "smoke:workflows": "node scripts/workflow-smoke.mjs",
    "smoke:backend:env": "node scripts/backend-env-smoke.mjs",
    "smoke:backend": "node scripts/backend-smoke.mjs",
    "smoke": "node scripts/smoke.mjs",
    "smoke:bff": "node scripts/bff-smoke.mjs",
    "smoke:bff:fetch": "node scripts/bff-fetch-smoke.mjs"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-5000720260410001",
    "@dcloudio/uni-h5": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-alipay": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-weixin": "3.0.0-5000720260410001",
    "pg": "^8.21.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@dcloudio/vite-plugin-uni": "3.0.0-5000720260410001",
    "vite": "5.2.8"
  }
}
